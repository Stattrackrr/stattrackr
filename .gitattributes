# Deep AFL training can produce RandomForest/HGB pickles > GitHub's 100 MB blob limit.
data/afl-model/models/*.pkl filter=lfs diff=lfs merge=lfs -text

# Keep workflow and source files UTF-8 + LF (avoid Windows UTF-16 breaking Turbopack/GitHub Actions).
.github/workflows/* text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
