{
  "ignoreCommand": "bash scripts/vercel-ignore-build-if-only-league-stats.sh",
  "crons": [
    {
      "path": "/api/check-journal-bets",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/odds/cleanup",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-odds-snapshots",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/afl/odds/refresh",
      "schedule": "0 0,3,6,9,12,15,18,21 * * *"
    },
    {
      "path": "/api/afl/odds/refresh",
      "schedule": "30 1,4,7,10,13,16,19,22 * * *"
    },
    {
      "path": "/api/afl/player-props/refresh",
      "schedule": "5 0,3,6,9,12,15,18,21 * * *"
    },
    {
      "path": "/api/afl/player-props/refresh",
      "schedule": "35 1,4,7,10,13,16,19,22 * * *"
    }
  ],
  "functions": {
    "app/api/shot-chart-enhanced/route.ts": {
      "maxDuration": 60
    },
    "app/api/play-type-analysis/route.ts": {
      "maxDuration": 60
    },
    "app/api/team-defense-rankings/route.ts": {
      "maxDuration": 60
    },
    "app/api/tracking-stats/team/route.ts": {
      "maxDuration": 60
    },
    "app/api/check-journal-bets/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/refresh-dvp-cache/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/refresh-defensive-stats/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/refresh-all-player-caches/route.ts": {
      "maxDuration": 600
    },
    "app/api/nba/player-props/process/route.ts": {
      "maxDuration": 300
    },
    "app/api/nba/player-props/update-odds/route.ts": {
      "maxDuration": 300
    },
    "app/api/tracking-stats/refresh/route.ts": {
      "maxDuration": 600
    },
    "app/api/cron/prefetch-advanced-stats/route.ts": {
      "maxDuration": 600
    },
    "app/api/cron/prefetch-daily-advanced-stats/route.ts": {
      "maxDuration": 300
    },
    "app/api/afl/odds/refresh/route.ts": {
      "maxDuration": 120
    },
    "app/api/afl/player-props/refresh/route.ts": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    {
      "source": "/api/webhooks/stripe",
      "destination": "/api/webhooks/stripe"
    },
    {
      "source": "/api/webhooks/stripe/",
      "destination": "/api/webhooks/stripe/"
    }
  ]
}
