{
  "name": "stattrackr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "warm:games": "node scripts/warm-games.js",
    "warm:rosters": "node scripts/warm-rosters.js",
    "logs": "node scripts/view-logs.js",
    "logs:json": "node scripts/view-logs.js --json",
    "logs:deployments": "vercel ls --prod",
    "process:player-props": "node scripts/process-player-props.js",
    "process:player-props:refresh": "node scripts/process-player-props.js --refresh",
    "audit:afl:active-stats": "node scripts/audit-afl-active-player-stats.js",
    "fetch:afl-roster": "node scripts/fetch-afl-roster.js",
    "build:afl:dvp": "node scripts/build-afl-dvp.js",
    "build:afl:dvp:depth": "node scripts/build-afl-dvp.js --mode=depth",
    "build:afl:dvp:local": "node scripts/build-afl-dvp.js --season=2026 --base-url=http://localhost:3000 --concurrency=4",
    "build:afl:dvp:depth:local": "node scripts/build-afl-dvp.js --mode=depth --season=2026 --base-url=http://localhost:3000 --concurrency=4",
    "run:afl:dvp-rankings": "node scripts/run-afl-dvp-rankings.js",
    "list:afl-roster": "node scripts/list-afl-roster.js",
    "fetch:footywire-team-rankings": "node scripts/fetch-footywire-team-rankings.js",
    "fetch:footywire-injuries": "node scripts/fetch-footywire-injuries.js",
    "fetch:footywire-league-player-stats": "node scripts/fetch-footywire-league-player-stats.js",
    "prefetch:afl:headshots": "npx tsx scripts/prefetch-afl-player-headshots.ts",
    "fetch:afl-2026-jumper-numbers": "node scripts/fetch-afl-2026-jumper-numbers.js",
    "fetch:footywire-ladder": "node scripts/fetch-footywire-ladder.js",
    "fix:afl-player-names-with-symbols": "node scripts/fix-afl-player-names-with-symbols.js",
    "warm:afl:player-logs": "node scripts/warm-afl-player-logs.js",
    "warm:soccer:cache": "node scripts/warm-soccer-cache.js",
    "refresh:soccer:team-results-cache": "npx tsx scripts/refresh-soccer-team-results-cache.ts",
    "refresh:soccer:view-cache": "npx tsx scripts/refresh-soccer-view-cache.ts",
    "refresh:soccer:dashboard-cache": "node scripts/refresh-soccer-dashboard-cache.js",
    "build:soccer:opponent-breakdown:pl": "node scripts/build-soccer-opponent-breakdown-pl.js",
    "build:soccer:team-matchup:pl": "node scripts/build-soccer-team-matchup-pl.js",
    "build:soccer:last5:pl": "node scripts/build-soccer-last5-pl.js",
    "test:afl:massimo": "node scripts/test-afl-player-massimo.js",
    "test:afl:2025-2026-logs": "node scripts/test-afl-2025-2026-logs.js",
    "test:afl:2025-2026-logs:all": "node scripts/test-afl-2025-2026-logs.js --all",
    "debug:afl:dvp": "node scripts/debug-afl-dvp-2026.js",
    "debug:afl:depth-role-vs-team": "node scripts/debug-afl-depth-role-vs-team.js",
    "show:afl:dvp-by-team": "node scripts/show-afl-dvp-by-team.js",
    "fetch:afl:dfs-usage": "node scripts/fetch-afl-dfs-usage.js",
    "fetch:afl:dfs-role-map": "node scripts/fetch-afl-dfs-role-map.js",
    "fetch:afl:weather-context": "node scripts/fetch-afl-weather-context.js",
    "test:afl:symbols": "node scripts/test-afl-symbol-players.js",
    "test:afl:headshots": "npx tsx scripts/test-afl-club-headshots.ts",
    "test:afl:team-selections": "node scripts/test-footywire-team-selections.js",
    "clear:player-props": "node scripts/clear-player-props-cache.js",
    "check:prediction-data": "node scripts/check-prediction-data-sources.mjs",
    "apply:prediction-tables": "node scripts/apply-prediction-engine-tables.mjs",
    "gh:workflows": "gh workflow list",
    "gh:logs": "gh run list --workflow=process-player-props.yml --limit 5",
    "gh:view": "gh run view --log",
    "demo:afl:journal": "node scripts/rebuild-afl-demo-journal-bets.js --apply",
    "afl:model:dataset": "python scripts/afl_model/build_dataset.py",
    "afl:model:train": "python scripts/afl_model/train_disposals_model.py",
    "afl:model:train:candidate": "python scripts/afl_model/train_disposals_model.py --candidate-only",
    "afl:model:score": "python scripts/afl_model/score_upcoming.py",
    "afl:model:score:candidate": "python scripts/afl_model/score_upcoming.py --artifact data/afl-model/models/latest-candidate-model.json --latest-output-path data/afl-model/latest-candidate-disposals-projections.json",
    "afl:model:evaluate": "python scripts/afl_model/evaluate_closed_loop.py --promote-if-pass --freeze-fail-streak 3 --candidate-artifact data/afl-model/models/latest-candidate-model.json --current-artifact data/afl-model/models/latest-model.json --candidate-projections data/afl-model/latest-candidate-disposals-projections.json",
    "afl:model:evaluate:ship": "python scripts/afl_model/evaluate_closed_loop.py --promote-if-pass --freeze-fail-streak 3 --skip-metric-guardrails --candidate-artifact data/afl-model/models/latest-candidate-model.json --current-artifact data/afl-model/models/latest-model.json --candidate-projections data/afl-model/latest-candidate-disposals-projections.json",
    "afl:model:evaluate:dry": "python scripts/afl_model/evaluate_closed_loop.py --candidate-artifact data/afl-model/models/latest-candidate-model.json --current-artifact data/afl-model/models/latest-model.json --candidate-projections data/afl-model/latest-candidate-disposals-projections.json",
    "afl:model:test-local": "powershell -ExecutionPolicy Bypass -File scripts/afl_model/test-local-training-loop.ps1",
    "afl:model:run": "python scripts/afl_model/build_dataset.py && python scripts/afl_model/train_disposals_model.py && python scripts/afl_model/score_upcoming.py"
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.2.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.57.3",
    "@upstash/redis": "^1.36.2",
    "dotenv": "^17.2.3",
    "json5": "^2.2.3",
    "lucide-react": "^0.543.0",
    "next": "^16.0.7",
    "overlayscrollbars": "^2.12.0",
    "overlayscrollbars-react": "^0.5.6",
    "puppeteer": "^24.31.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.2.0",
    "resend": "^6.8.0",
    "stripe": "^19.2.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.23",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react-devtools": "^7.0.0",
    "typescript": "^5"
  }
}
